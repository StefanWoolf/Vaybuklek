# ─────────────────────────────────────────────────────────────────────────────
# Дирижёр — пример конфигурации.
# Скопируйте в `.env` и заполните. Пустые ключи => соответствующий компонент
# работает в MOCK-режиме (всё запускается и демонстрируется без внешних API).
# Файл .env в git не коммитится (см. .gitignore). НИЧЕГО не хардкодим в коде.
# ─────────────────────────────────────────────────────────────────────────────

# ── Общее ────────────────────────────────────────────────────────────────────
# Часовой пояс для расписаний (напоминания, вечерняя сверка)
DIRIZHER_TIMEZONE=Europe/Moscow
# Уровень логирования: DEBUG | INFO | WARNING | ERROR
DIRIZHER_LOG_LEVEL=INFO

# ── Telegram ─────────────────────────────────────────────────────────────────
# Токен бота от @BotFather. Пусто => бот работает в mock-режиме (без сети).
DIRIZHER_TELEGRAM__BOT_TOKEN=
# Режим получения апдейтов: polling (для разработки) | webhook (для прод/n8n)
DIRIZHER_TELEGRAM__MODE=polling
# Базовый публичный URL для webhook-режима (например, https://example.com)
DIRIZHER_TELEGRAM__WEBHOOK_BASE_URL=
# ID рабочего чата команды (необязательно; определится автоматически)
DIRIZHER_TELEGRAM__TEAM_CHAT_ID=

# ── LLM (извлечение задач) ───────────────────────────────────────────────────
# Провайдер: mock | groq | gigachat. Пустой ключ провайдера => принудительно mock.
DIRIZHER_LLM__PROVIDER=mock
# Порог уверенности: ниже него бот уточняет задачу у участника
DIRIZHER_LLM__CONFIDENCE_THRESHOLD=0.7
# Groq
DIRIZHER_LLM__GROQ_API_KEY=
# Доп. ключи Groq через запятую — авто-ротация при дневном лимите токенов (429)
DIRIZHER_LLM__GROQ_API_KEYS=
DIRIZHER_LLM__GROQ_MODEL=llama-3.3-70b-versatile
# GigaChat (Sber)
DIRIZHER_LLM__GIGACHAT_CREDENTIALS=
DIRIZHER_LLM__GIGACHAT_SCOPE=GIGACHAT_API_PERS

# ── YouGile (канбан-доска) ───────────────────────────────────────────────────
# Пусто => mock-доска в памяти (карточки создаются, видны в логах и /board)
DIRIZHER_YOUGILE__API_KEY=
DIRIZHER_YOUGILE__BASE_URL=https://ru.yougile.com/api-v2
# ID колонок доски (необязательно; в mock не требуется)
DIRIZHER_YOUGILE__COLUMN_TODO=
DIRIZHER_YOUGILE__COLUMN_IN_PROGRESS=
DIRIZHER_YOUGILE__COLUMN_DONE=

# ── Память / дедупликация ────────────────────────────────────────────────────
# backend: lexical (по умолчанию, без сети) | chroma (семантический поиск;
# при первом старте скачает embedding-модель ~80МБ)
DIRIZHER_MEMORY__BACKEND=lexical
# Каталог персистентного хранилища векторной памяти (для backend=chroma)
DIRIZHER_MEMORY__CHROMA_PATH=./.data/chroma
# Порог косинусной близости для признания задач дублями (0..1)
DIRIZHER_MEMORY__DEDUP_THRESHOLD=0.83
# Путь к живому MD-снимку проекта, который бот обновляет сам
DIRIZHER_MEMORY__PROJECT_SNAPSHOT=./.data/project.md

# ── Аудио (встречи, голосовые) — Этап 3 ──────────────────────────────────────
# Пусто/false => mock-транскрипция (детерминированная заглушка для демо)
DIRIZHER_AUDIO__ENABLED=false
DIRIZHER_AUDIO__WHISPER_MODEL=small
DIRIZHER_AUDIO__GROQ_API_KEY=
DIRIZHER_AUDIO__HF_TOKEN=

# ── Расписания (cron) ────────────────────────────────────────────────────────
# Утренняя сводка задач на день (дедлайны сегодня + просрочки)
DIRIZHER_SCHEDULE__MORNING_DIGEST_CRON=0 9 * * *
# Когда проверять дедлайны и слать напоминания
DIRIZHER_SCHEDULE__REMINDER_CRON=0 10,15 * * *
# Когда запускать вечернюю сверку отчётов
DIRIZHER_SCHEDULE__EVENING_RECONCILE_CRON=0 20 * * *
# Когда постить игровой лидерборд (по умолчанию — пятница 18:00)
DIRIZHER_SCHEDULE__LEADERBOARD_CRON=0 18 * * 5
# За сколько часов до дедлайна предупреждать
DIRIZHER_SCHEDULE__REMIND_BEFORE_HOURS=24

# ── HTTP API (для оркестрации n8n) ───────────────────────────────────────────
DIRIZHER_API__HOST=0.0.0.0
DIRIZHER_API__PORT=8080
# Общий секрет: n8n шлёт его в заголовке X-Dirizher-Token
DIRIZHER_API__SHARED_SECRET=
